{
  "manifest_version": 3,
  "name": "Token Optimizer",
  "version": "0.1.0",
  "description": "Shortens your AI chat prompts so they use fewer tokens, right in the browser.",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["https://*.run.app/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Token Optimizer — focus a text box to optimize it",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
