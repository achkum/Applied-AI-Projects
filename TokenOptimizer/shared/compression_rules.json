{
  "version": 2,
  "regex_constraints": "Patterns MUST use the JavaScript-compatible regex subset: NO variable-length lookbehind, NO named groups (?P<...>), NO inline flags. The same patterns run under Python re (flags per the 'flags' field) AND JS RegExp in the browser extension. 'scope':'prose' rules never touch code fences, inline backticks, or double-quoted spans. Rules apply in array order.",
  "tiers": {
    "safe": "Removes pure conversational scaffolding that carries no task information (greetings, sign-offs, politeness wrappers, meta-narration, verbose-for-plain substitutions). Meaning is preserved; applied by default.",
    "lossy": "Removes intensifiers and hedges that shade emphasis or certainty (very, really, basically, maybe, I think). Meaning is mostly preserved but nuance can shift; opt-in only."
  },
  "rules": [
    { "id": "politeness_could_you_please", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\b(?:could|would|can) you please\\b", "replacement": "please" },
    { "id": "politeness_please_could", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bplease could you\\b", "replacement": "please" },
    { "id": "politeness_i_was_wondering", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bI was wondering if you could\\b", "replacement": "Please" },
    { "id": "politeness_would_it_be_possible", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bwould it be possible (?:for you )?to\\b", "replacement": "please" },
    { "id": "politeness_i_would_like_you_to", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bI(?:'d| would) (?:like|want|need) (?:you )?to\\b", "replacement": "Please" },
    { "id": "politeness_go_ahead_and", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\b(?:please )?go ahead and\\b", "replacement": "please" },
    { "id": "politeness_feel_free_to", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bfeel free to\\b\\s*" },
    { "id": "politeness_if_you_dont_mind", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bif you (?:don'?t|do not) mind,?\\s*" },
    { "id": "politeness_when_you_get_a_chance", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": ",?\\s*when(?:ever)? you (?:get|have) (?:a chance|time)\\b" },
    { "id": "greeting", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gim",
      "pattern": "^(?:hi|hey|hello|greetings|good (?:morning|afternoon|evening))\\b[!,.\\s]*" },
    { "id": "signoff_thanks", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\s*\\b(?:thanks(?: in advance| so much)?|thank you|cheers|best(?: regards)?|regards|many thanks)\\b[!.\\s]*$" },
    { "id": "signoff_appreciate", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bI (?:really )?(?:appreciate (?:it|your help|any help)|would appreciate)\\b[!.\\s]*" },
    { "id": "meta_as_i_mentioned", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bas I (?:mentioned|said|noted|stated) (?:earlier|before|previously|above),?\\s*" },
    { "id": "meta_as_you_know", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bas you (?:know|can see|may know|are aware),?\\s*" },
    { "id": "meta_worth_noting", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bit (?:is|'s) worth noting that\\s*" },
    { "id": "meta_needless_to_say", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bneedless to say,?\\s*" },
    { "id": "meta_for_what_its_worth", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bfor what it'?s worth,?\\s*" },
    { "id": "filler_just_to_clarify", "tier": "safe", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bjust (?:to clarify|wanted to (?:ask|say|check)),?\\s*" },
    { "id": "verbose_in_order_to", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bin order to\\b", "replacement": "to" },
    { "id": "verbose_due_to_the_fact", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bdue to the fact that\\b", "replacement": "because" },
    { "id": "verbose_at_this_point_in_time", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bat this (?:point in time|moment in time)\\b", "replacement": "now" },
    { "id": "verbose_in_the_event_that", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bin the event that\\b", "replacement": "if" },
    { "id": "verbose_a_number_of", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\ba (?:large|great|small) number of\\b", "replacement": "many" },
    { "id": "verbose_in_spite_of_the_fact", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bin spite of the fact that\\b", "replacement": "although" },
    { "id": "verbose_the_fact_that", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bthe fact that\\b", "replacement": "that" },
    { "id": "verbose_with_regard_to", "tier": "safe", "type": "replace", "scope": "prose", "flags": "gi",
      "pattern": "\\bwith (?:regard|respect|reference) to\\b", "replacement": "about" },
    { "id": "dedup_sentences", "tier": "safe", "type": "dedup_sentences", "scope": "prose", "flags": "" },
    { "id": "squeeze_ws", "tier": "safe", "type": "squeeze_ws", "scope": "prose", "flags": "" },

    { "id": "intensifiers", "tier": "lossy", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\b(?:basically|essentially|actually|literally|seriously|honestly|frankly|simply|really|very|quite|rather|somewhat|fairly|truly|extremely|incredibly|absolutely)\\s+" },
    { "id": "hedge_i_think", "tier": "lossy", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bI (?:think|believe|guess|suppose|feel)(?: that)?\\s+" },
    { "id": "hedge_sort_of", "tier": "lossy", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\b(?:sort of|kind of|kinda|sorta)\\s+" },
    { "id": "hedge_maybe", "tier": "lossy", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\b(?:maybe|perhaps|possibly|probably)\\s+" },
    { "id": "hedge_to_be_honest", "tier": "lossy", "type": "delete", "scope": "prose", "flags": "gi",
      "pattern": "\\bto be (?:honest|fair|clear),?\\s*" }
  ]
}
