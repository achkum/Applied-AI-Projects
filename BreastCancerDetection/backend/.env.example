# Local path to the trained ResNet50 weights (.pth). Leave empty to run an untrained fallback.
MODEL_PATH=

# GCS URI for the weights (used in Cloud Run; downloaded at startup if MODEL_PATH is unset).
MODEL_GCS_URI=gs://your-project-models/resnet50_breakhis_400x.pth

# Decision boundary for benign vs malignant (overridden by model_metadata.json if present).
DECISION_THRESHOLD=0.5

# +/- band around the threshold for the "uncertain, review" triage tier.
UNCERTAINTY_MARGIN=0.15

# Comma-separated list of allowed CORS origins (the frontend).
ALLOWED_ORIGINS=http://localhost:3000

# Max upload size in MB.
MAX_UPLOAD_MB=10

# Gemini API key (Google AI Studio free tier) — required for the /chat agent.
GEMINI_API_KEY=
